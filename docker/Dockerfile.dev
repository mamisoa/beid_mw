FROM python:3.12-slim-bookworm

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYKCS11LIB=/usr/lib/x86_64-linux-gnu/libbeidpkcs11.so.0

# Install system dependencies for pykcs11 and eID middleware
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
    libpcsclite-dev \
    pcsc-tools \
    usbutils \
    wget \
    ca-certificates \
    gnupg \
    libc6 \
    libcap2-bin \
    curl \
    build-essential \
    swig \
    && rm -rf /var/lib/apt/lists/*

# Install uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

# Configure eID Belgium repo with GPG key and install middleware
COPY docker/eid-released.gpg /usr/share/keyrings/eid-belgium.gpg
RUN echo "deb [signed-by=/usr/share/keyrings/eid-belgium.gpg] https://files.eid.belgium.be/debian bookworm main" > /etc/apt/sources.list.d/eid.list \
    && apt-get update \
    && apt-get install -y eid-mw \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy startup script to a location not overridden by volume mount
COPY docker/start-dev.sh /usr/local/bin/start-dev.sh
RUN chmod +x /usr/local/bin/start-dev.sh

# Command to run the application
CMD ["/usr/local/bin/start-dev.sh"]
